# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Get a Gemini Developer API key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_key_here

# Set to FALSE to use the Gemini Developer API (default for local dev).
# Set to TRUE to use Vertex AI; then also set GOOGLE_CLOUD_PROJECT and
# GOOGLE_CLOUD_LOCATION, and run `gcloud auth application-default login`.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
